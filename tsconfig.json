{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "types": ["jest", "react", "react-dom"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./public/build",
    "rootDir": "./assets",
    "baseUrl": "./assets",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["assets/**/*"],
  "exclude": ["node_modules", "public"]
}
